from pathlib import Path
import pandas as pd
import matplotlib.pyplot as plt

PROJECT_ROOT = Path(__file__).resolve().parents[2]
INPUT_PATH = PROJECT_ROOT / "01_data" / "01_processed" / "train_bianca_features.csv"
OUTPUT_DIR = PROJECT_ROOT / "04_visuals" / "bianca_eda"

FEATURE_COLS = [
    "profanity_word_count",
    "obfuscated_profanity_count",
    "abusive_dependency_tuple_count",
]

LABEL_COLS = [
    "toxic",
    "severe_toxic",
    "obscene",
    "threat",
    "insult",
    "identity_hate",
]

PRIMARY_LABEL = "any_toxic"


def ensure_output_dir():
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)


def load_data() -> pd.DataFrame:
    if not INPUT_PATH.exists():
        raise FileNotFoundError(
            f"Could not find processed feature file at {INPUT_PATH}. "
            "Run run_bianca_features.py first."
        )
    return pd.read_csv(INPUT_PATH)


def save_text_report(df: pd.DataFrame):
    report_path = OUTPUT_DIR / "bianca_eda_summary.txt"

    with open(report_path, "w", encoding="utf-8") as f:
        f.write("BIANCA FEATURE EDA SUMMARY\n")
        f.write("=" * 50 + "\n\n")

        f.write(f"Dataset shape: {df.shape}\n\n")

        f.write("Missing values\n")
        f.write("-" * 30 + "\n")
        f.write(df[FEATURE_COLS].isnull().sum().to_string())
        f.write("\n\n")

        f.write("Descriptive statistics\n")
        f.write("-" * 30 + "\n")
        f.write(df[FEATURE_COLS].describe().to_string())
        f.write("\n\n")

        if PRIMARY_LABEL in df.columns:
            f.write(f"Mean feature values by {PRIMARY_LABEL}\n")
            f.write("-" * 30 + "\n")
            f.write(df.groupby(PRIMARY_LABEL)[FEATURE_COLS].mean().to_string())
            f.write("\n\n")

        existing_labels = [col for col in LABEL_COLS if col in df.columns]
        for label in existing_labels:
            f.write(f"Mean feature values by {label}\n")
            f.write("-" * 30 + "\n")
            f.write(df.groupby(label)[FEATURE_COLS].mean().to_string())
            f.write("\n\n")

        numeric_cols = [c for c in FEATURE_COLS if c in df.columns]
        if PRIMARY_LABEL in df.columns:
            corr_df = df[numeric_cols + [PRIMARY_LABEL]].corr(numeric_only=True)
            f.write(f"Correlation with {PRIMARY_LABEL}\n")
            f.write("-" * 30 + "\n")
            f.write(corr_df[PRIMARY_LABEL].sort_values(ascending=False).to_string())
            f.write("\n\n")

    print(f"Saved text summary to: {report_path}")


def plot_histograms(df: pd.DataFrame):
    for col in FEATURE_COLS:
        plt.figure(figsize=(7, 4))
        df[col].fillna(0).hist(bins=30)
        plt.title(f"Distribution of {col}")
        plt.xlabel(col)
        plt.ylabel("Frequency")
        plt.tight_layout()
        out_path = OUTPUT_DIR / f"hist_{col}.png"
        plt.savefig(out_path, dpi=200, bbox_inches="tight")
        plt.close()
        print(f"Saved: {out_path}")


def plot_boxplots_by_label(df: pd.DataFrame, label_col: str):
    if label_col not in df.columns:
        return

    for col in FEATURE_COLS:
        plt.figure(figsize=(7, 4))
        df.boxplot(column=col, by=label_col)
        plt.title(f"{col} by {label_col}")
        plt.suptitle("")
        plt.xlabel(label_col)
        plt.ylabel(col)
        plt.tight_layout()
        out_path = OUTPUT_DIR / f"box_{col}_by_{label_col}.png"
        plt.savefig(out_path, dpi=200, bbox_inches="tight")
        plt.close()
        print(f"Saved: {out_path}")


def plot_mean_bar_by_label(df: pd.DataFrame, label_col: str):
    if label_col not in df.columns:
        return

    grouped = df.groupby(label_col)[FEATURE_COLS].mean()

    for col in FEATURE_COLS:
        plt.figure(figsize=(6, 4))
        grouped[col].plot(kind="bar")
        plt.title(f"Mean {col} by {label_col}")
        plt.xlabel(label_col)
        plt.ylabel(f"Mean {col}")
        plt.tight_layout()
        out_path = OUTPUT_DIR / f"mean_{col}_by_{label_col}.png"
        plt.savefig(out_path, dpi=200, bbox_inches="tight")
        plt.close()
        print(f"Saved: {out_path}")


def print_console_summary(df: pd.DataFrame):
    print("\nDataset shape:")
    print(df.shape)

    print("\nMissing values:")
    print(df[FEATURE_COLS].isnull().sum())

    print("\nDescriptive statistics:")
    print(df[FEATURE_COLS].describe())

    if PRIMARY_LABEL in df.columns:
        print(f"\nMean feature values by {PRIMARY_LABEL}:")
        print(df.groupby(PRIMARY_LABEL)[FEATURE_COLS].mean())

    existing_labels = [col for col in LABEL_COLS if col in df.columns]
    for label in existing_labels:
        print(f"\nMean feature values by {label}:")
        print(df.groupby(label)[FEATURE_COLS].mean())


def main():
    ensure_output_dir()
    df = load_data()

    required_cols = FEATURE_COLS.copy()
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise ValueError(
            f"Missing required feature columns: {missing}. "
            "Check that run_bianca_features.py created them correctly."
        )

    print_console_summary(df)
    save_text_report(df)
    plot_histograms(df)

    plot_boxplots_by_label(df, PRIMARY_LABEL)
    plot_mean_bar_by_label(df, PRIMARY_LABEL)

    existing_labels = [col for col in LABEL_COLS if col in df.columns]
    for label in existing_labels:
        plot_boxplots_by_label(df, label)
        plot_mean_bar_by_label(df, label)

    print(f"\nEDA outputs saved in: {OUTPUT_DIR}")


if __name__ == "__main__":
    main()